  <title>Notes App – Portfolio Project</title>
  <style>
    /* ── Reset & Base ─────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0f1117;
      --surface:   #1a1d27;
      --border:    #2e3147;
      --accent:    #6c63ff;
      --accent-h:  #8a84ff;
      --text:      #e2e4f0;
      --muted:     #7b7f96;
      --tag-bg:    #23263a;
      --radius:    14px;
      --shadow:    0 8px 32px rgba(0,0,0,.45);
    }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 60px 24px 80px;
      line-height: 1.6;
    }

    /* ── Page Header ──────────────────────────────── */
    header {
      text-align: center;
      margin-bottom: 52px;
    }
    header .label {
      font-size: .75rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }
    header h1 {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 700;
      background: linear-gradient(135deg, #fff 30%, var(--accent-h));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    header p {
      color: var(--muted);
      margin-top: 10px;
      font-size: .95rem;
    }

    /* ── Two-column grid ──────────────────────────── */
    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      width: 100%;
      max-width: 1080px;
    }
    @media (max-width: 720px) {
      .grid { grid-template-columns: 1fr; }
    }

    /* ── Card ─────────────────────────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px 28px;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
    }

    .card-badge {
      display: inline-block;
      font-size: .7rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      background: var(--tag-bg);
      color: var(--accent-h);
      border: 1px solid var(--border);
      border-radius: 50px;
      padding: 4px 12px;
      margin-bottom: 16px;
      width: fit-content;
    }

    .card h2 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 20px;
      color: #fff;
    }

    /* ── Overview Card ────────────────────────────── */
    .overview-card .section-title {
      font-size: .7rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 18px 0 6px;
