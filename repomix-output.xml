<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Me – Michael Needham</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css">
  <link rel="stylesheet" href="carousel.css">
  <link rel="stylesheet" href="bg-anim.css">
  <style>
    :root {
      --am-surface:  #13141f;
      --am-border:   #252740;
      --am-muted:    #6b7099;
      --am-tag-bg:   #1c1e30;
      --am-radius:   14px;
      --am-shadow:   0 8px 40px rgba(0,0,0,.55);
      --am-rainbow:  linear-gradient(135deg, #f97316, #eab308, #22c55e, #06b6d4, #6366f1, #a855f7, #ec4899);
    }

    body { background: #0a0a0f; }

    /* ── Page layout ───────────────────────────────── */
    .am-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 24px 24px 60px;
      min-height: 100vh;
      position: relative;
      z-index: 10;
    }

    .am-header {
      text-align: center;
      margin-bottom: 28px;
      padding: 32px 48px 28px;
      background: rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 72px;
      overflow: hidden;
      box-shadow:
        0 0 40px rgba(102, 126, 234, 0.18),
        0 8px 40px rgba(0, 0, 0, 0.45),
        inset 0 0 20px rgba(255, 255, 255, 0.03);
      max-width: 600px;
      width: 100%;
    }
    .am-header .label {
      display: block;
      font-size: .7rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      background: var(--am-rainbow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 12px;
      font-weight: 700;
    }
    .am-header h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #fff;
