<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ORDINAL 🌈 RAINBOWS – Portfolio Project</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css">
  <link rel="stylesheet" href="carousel.css">
  <link rel="stylesheet" href="bg-anim.css">
  <style>
    /* Page-specific variables */
    :root {
      --or-surface:  #13141f;
      --or-border:   #252740;
      --or-muted:    #6b7099;
      --or-tag-bg:   #1c1e30;
      --or-radius:   14px;
      --or-shadow:   0 8px 40px rgba(0,0,0,.55);
      --or-rainbow:  linear-gradient(135deg, #f97316, #eab308, #22c55e, #06b6d4, #6366f1, #a855f7, #ec4899);
    }

    body { background: #0a0a0f; }

    /* ── Page layout ──────────────────────────────── */
    .or-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 24px 24px 40px;
      min-height: 100vh;
      position: relative;
      z-index: 10;
    }

    .or-header {
      text-align: center;
      margin-bottom: 24px;
      padding: 32px 48px 28px;
      background: rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 72px;
      overflow: hidden;
      box-shadow:
        0 0 40px rgba(102, 126, 234, 0.18),
        0 8px 40px rgba(0, 0, 0, 0.45),
        inset 0 0 20px rgba(255, 255, 255, 0.03);
      max-width: 700px;
      width: 100%;
    }
    .or-header h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #fff;
      text-shadow:
        0 0 28px rgba(102, 126, 234, 0.6),
        0 0 60px rgba(102, 126, 234, 0.2),
        0 2px 12px rgba(0, 0, 0, 0.8);
      margin: 0 0 4px;
    }
    .or-header .label {
      display: block;
      font-size: .7rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      background: var(--or-rainbow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 12px;
      font-weight: 700;
    }
    .or-header p {
      margin-top: 8px;
      font-size: .9rem;
      background: var(--or-rainbow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Two-column grid ──────────────────────────── */
    .or-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      width: 100%;
      max-width: 1080px;
    }
    @media (max-width: 720px) {
      .or-grid { grid-template-columns: 1fr; }
    }

    /* ── Card ─────────────────────────────────────── */
    .or-card {
      background: var(--or-surface);
      border: 1px solid var(--or-border);
      border-radius: var(--or-radius);
      padding: 32px 28px;
      box-shadow: var(--or-shadow);
      display: flex;
      flex-direction: column;
    }
    .or-card::before {
      content: '';
      display: block;
      height: 3px;
      background: var(--or-rainbow);
      margin: -32px -28px 24px;
      border-radius: calc(var(--or-radius) - 1px) calc(var(--or-radius) - 1px) 0 0;
    }
    .or-card-badge {
      display: inline-block;
      font-size: .7rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      background: var(--or-tag-bg);
      color: #a855f7;
      border: 1px solid var(--or-border);
      border-radius: 50px;
      padding: 4px 12px;
      margin-bottom: 16px;
      width: fit-content;
    }
    .or-card h2 {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 20px;
      color: #fff;
    }
    .or-section-title {
      font-size: .7rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--or-muted);
      margin: 18px 0 6px;
    }
    .or-section-title:first-of-type { margin-top: 0; }
    .or-card p, .or-card li {
      font-size: 1rem;
      color: #b8bbda;
    }

    /* ── Tags ─────────────────────────────────────── */
    .or-tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 10px 0 4px;
    }
    .or-tag {
      font-size: .75rem;
      background: var(--or-tag-bg);
      border: 1px solid var(--or-border);
      border-radius: 50px;
      padding: 3px 10px;
    }
    .or-tag:nth-child(7n+1) { color: #f97316; border-color: rgba(249,115,22,.35); }
