    .overview-card p, .overview-card li {
      font-size: .9rem;
      color: #bbbdd4;
    }

    .overview-card .situation p { color: #d0d2e8; font-size: .95rem; }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 10px 0 4px;
