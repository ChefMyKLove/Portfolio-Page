const ArtCarousel = {
    init() {
        const artworks = [
            { 
                image: 'images/TunnelBow.JPEG', 
                printifyUrl: 'https://ordinalrainbows.printify.me/product/25134633/tunnelbow',
                title: 'TunnelBow',
