  }
  
  h1 {
    font-size: 2.2em;
  }
  
  h3 {
    font-size: 1.8em;
  }
  
  h4 {
    font-size: 2.2em;
  }
  
  .title {
    font-size: 1.5em;
  }
  
  nav ul {
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    padding: 5px;
