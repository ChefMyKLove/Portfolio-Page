/* CONTENT BLOCK POSITIONING */
#content-wrapper .container, .blurb, .latest, .post, .further-info, 
.contents-section, .header h1, .header h2 {
  position: relative;
  background: transparent !important;
}

/* ANIMATED PSEUDO-ELEMENT BACKGROUNDS — each box gets its own image cycle */
#content-wrapper .container::before, .blurb::before, .latest::before, 
.post::before, .further-info::before, .contents-section::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  z-index: -1;
  border-radius: inherit;
  animation: blogBackgroundCycle 78s infinite ease-in-out;
  will-change: background-image;
}

/* CONTAINER — transparent, glassmorphism handled by backdrop-filter */
#content-wrapper .container::before {
  background-color: transparent;
  animation: blogBackgroundCycle 104s infinite ease-in-out;
}

/* CONTENT BLOCKS — each at a different speed so they drift out of sync */
.blurb::before { 
  background-color: rgba(0, 0, 0, 0.3);
  animation: blogBackgroundCycle 156s infinite ease-in-out;
}
.latest::before { 
  background-color: rgba(0, 0, 0, 0.2);
  animation: blogBackgroundCycle 120s infinite ease-in-out;
}
.post::before { 
  background-color: rgba(0, 0, 0, 0.1);
  animation: blogBackgroundCycle 104s infinite linear;
}
.further-info::before { 
  background-color: rgba(0, 0, 0, 0.25);
  animation: blogBackgroundCycle 135s infinite ease-in-out;
}
.contents-section::before {
  background-color: rgba(0, 0, 0, 0.15);
  animation: blogBackgroundCycle 165s infinite ease-in-out;
}

/* CENTER SWATH */
#content-wrapper .container {
  max-width: 900px;
  margin: 0 auto;
  min-height: 100vh;
  padding: 40px;
  border-radius: 0;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(255,255,255,0.08);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.08);
}

.header h1 { 
